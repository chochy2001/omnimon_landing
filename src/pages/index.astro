---
import Layout from '../layouts/Layout.astro';
import { OMNIMON_VERSION, RELEASE_DATE } from '../consts';

const releaseVersion = OMNIMON_VERSION;
const releaseDate = RELEASE_DATE;
const releaseUrl = 'https://github.com/chochy2001/omnimon/releases/latest';
const docsUrl = 'https://github.com/chochy2001/omnimon#readme';
const sponsorUrl = 'https://github.com/sponsors/chochy2001';
const installScriptUrl = 'https://raw.githubusercontent.com/chochy2001/omnimon/main/scripts/install-web.sh';

const downloadArtifacts = [
	{
		platform: 'macOS',
		name: 'Universal DMG',
		description: 'Descarga el release mas reciente para Apple Silicon e Intel desde GitHub Releases.',
		accent: 'text-orange-200',
		sha256: 'Disponible en SHA256SUMS.txt del release oficial'
	},
	{
		platform: 'Windows',
		name: 'MSI oficial',
		description: 'Instala OmniMon desde el paquete MSI publicado en el ultimo release oficial.',
		accent: 'text-sky-200',
		sha256: 'Verifica el MSI con SHA256SUMS.txt antes de instalar'
	},
	{
		platform: 'Linux',
		name: 'Script + paquetes',
		description: 'Usa el instalador web o descarga `.deb` y `.AppImage` desde el release mas reciente.',
		accent: 'text-emerald-200',
		sha256: 'Checksums SHA-256 publicados junto al `.deb` y `.AppImage`'
	}
];

const releaseHighlights = [
	{
		title: 'Kill dialog inteligente',
		description: 'Al terminar navegadores, el dialogo muestra las pestanas abiertas que se cerraran. Nuevo boton "Preguntar a la IA" para analizar si es seguro terminar un proceso.'
	},
	{
		title: 'Graficas dinamicas corregidas',
		description: 'Sparklines y modales de graficas ahora renderizan de forma confiable con escalado dinamico Y, reintentos automaticos y sincronizacion incremental de datos.'
	},
	{
		title: 'Sistema de temas unificado',
		description: 'Se elimino el sistema de temas duplicado que causaba conflictos. Un solo motor de temas (dark, light, cyberpunk) con auto-deteccion de preferencia del sistema.'
	},
	{
		title: 'Detalles de proceso mejorados',
		description: 'El modal de detalles ahora muestra pestanas del navegador en modo basico, no solo en modo Pro. Layout full-width responsive para todos los paneles.'
	}
];

const productPillars = [
	{
		title: 'Desktop nativo',
		description: 'UI en Tauri + Svelte 5 con telemetria en tiempo real, paneles de seguridad y temas integrados.',
		accent: 'text-sky-300'
	},
	{
		title: 'CLI y TUI',
		description: 'Mismas capacidades clave desde terminal para servidores, automatizacion y diagnosticos rapidos.',
		accent: 'text-emerald-300'
	},
	{
		title: 'Seguridad operativa',
		description: 'Auditoria local, reglas, telemetria de red y controles para reducir errores y detectar anomalias antes.',
		accent: 'text-orange-300'
	}
];

const basicTutorial = [
	{
		step: '1',
		title: 'Abre OmniMon y revisa el dashboard',
		description: 'Empieza con CPU, RAM, red y procesos visibles para detectar rapidamente si el equipo esta estable o degradado.'
	},
	{
		step: '2',
		title: 'Filtra el ruido y enfoca el problema',
		description: 'Usa busqueda, agrupacion y tablas de procesos o conexiones para aislar la app, host o pico que te interesa.'
	},
	{
		step: '3',
		title: 'Pide contexto a la IA o ejecuta un audit',
		description: 'Puedes mantenerlo manual o apoyarte en IA/CLI para resumir consumo, explicar alertas y sugerir acciones.'
	},
	{
		step: '4',
		title: 'Verifica el release que instalas',
		description: 'Antes de desplegar en mas equipos, valida el artefacto contra `SHA256SUMS.txt` y la firma publicada del release.'
	}
];

const faqs = [
	{
		question: `Que incluye la version ${releaseVersion}?`,
		answer: 'Incluye kill dialog inteligente con pestanas del navegador y boton de IA, graficas dinamicas corregidas, sistema de temas unificado sin conflictos, y detalles de proceso mejorados con tabs visibles en modo basico.'
	},
	{
		question: 'En que plataformas funciona OmniMon?',
		answer: 'OmniMon esta pensado para macOS, Windows y Linux, con app de escritorio, CLI y TUI compartiendo la misma base de capacidades.'
	},
	{
		question: 'La IA es obligatoria?',
		answer: 'No. Puedes usar OmniMon como monitor y panel de seguridad sin IA, o activar proveedores locales y cloud cuando necesites analisis asistido.'
	},
	{
		question: 'Como verifico una descarga?',
		answer: 'Descarga el artefacto desde GitHub Releases y compara su hash con `SHA256SUMS.txt`. Si necesitas mas garantia, valida tambien la firma del release.'
	}
];
---

<Layout
	title={`OmniMon ${releaseVersion} | Observabilidad, seguridad e IA para tu sistema`}
	description={`Landing oficial de OmniMon ${releaseVersion} con novedades del release, tutorial basico, descargas verificables y accesos rapidos para macOS, Windows y Linux.`}
>
	<main class="mx-auto flex w-full max-w-7xl flex-col gap-24 px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
		<section class="grid-noise glass-panel relative overflow-hidden rounded-[2rem] px-6 py-12 sm:px-10 lg:px-12">
			<div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-sky-300/50 to-transparent"></div>
			<div class="grid gap-12 lg:grid-cols-[1.2fr_0.8fr] lg:items-center">
				<div class="space-y-8">
					<div class="inline-flex items-center gap-3 rounded-full border border-sky-300/20 bg-slate-950/60 px-4 py-2 text-sm text-sky-100">
						<span class="rounded-full bg-orange-500/20 px-2 py-1 text-orange-200">Nuevo</span>
						<span>Version {releaseVersion}</span>
						<span class="text-slate-500">|</span>
						<span class="text-slate-300">Release {releaseDate}</span>
					</div>

					<div class="space-y-5">
						<h1 class="section-title max-w-4xl text-5xl font-black tracking-tight text-white sm:text-6xl lg:text-7xl">
							Observabilidad real, seguridad activa y asistencia IA en una sola consola.
						</h1>
						<p class="max-w-2xl text-lg leading-8 text-slate-300 sm:text-xl">
							OmniMon {releaseVersion} une desktop nativo, CLI y TUI para monitorear procesos, red, alertas y automatizaciones sin perder rendimiento ni contexto operativo.
						</p>
					</div>

					<div class="flex flex-col gap-4 sm:flex-row">
						<a href="#download" class="inline-flex items-center justify-center rounded-full bg-orange-500 px-7 py-3.5 font-semibold text-slate-950 transition hover:bg-orange-400">
							Descargar {releaseVersion}
						</a>
						<a href={docsUrl} target="_blank" rel="noreferrer" class="inline-flex items-center justify-center rounded-full border border-slate-700 bg-slate-900/70 px-7 py-3.5 font-semibold text-white transition hover:border-sky-300/40 hover:bg-slate-900">
							Ver documentacion
						</a>
						<a href={sponsorUrl} target="_blank" rel="noreferrer" class="inline-flex items-center justify-center rounded-full border border-orange-300/30 bg-orange-500/10 px-7 py-3.5 font-semibold text-orange-100 transition hover:border-orange-200/60 hover:bg-orange-500/20">
							GitHub Sponsors
						</a>
					</div>

					<div class="grid gap-3 text-sm text-slate-300 sm:grid-cols-3">
						<div class="rounded-2xl border border-slate-800/80 bg-slate-950/60 p-4">
							<p class="text-xs uppercase tracking-[0.24em] text-slate-500">Plataformas</p>
							<p class="mt-2 font-semibold text-white">macOS, Windows y Linux</p>
						</div>
						<div class="rounded-2xl border border-slate-800/80 bg-slate-950/60 p-4">
							<p class="text-xs uppercase tracking-[0.24em] text-slate-500">Seguridad</p>
							<p class="mt-2 font-semibold text-white">Firmas Ed25519 + SHA-256</p>
						</div>
						<div class="rounded-2xl border border-slate-800/80 bg-slate-950/60 p-4">
							<p class="text-xs uppercase tracking-[0.24em] text-slate-500">IA opcional</p>
							<p class="mt-2 font-semibold text-white">Local o cloud segun tu flujo</p>
						</div>
					</div>
				</div>

				<div class="glass-panel rounded-[1.75rem] border-slate-700/70 p-5">
					<div class="mb-4 flex items-center justify-between">
						<div>
							<p class="text-xs uppercase tracking-[0.28em] text-slate-500">Release snapshot</p>
							<h2 class="mt-2 text-2xl font-bold text-white">OmniMon {releaseVersion}</h2>
						</div>
						<a href={releaseUrl} target="_blank" rel="noreferrer" class="rounded-full border border-sky-300/20 px-3 py-1 text-sm text-sky-200 transition hover:border-sky-300/40 hover:text-white">Ver release</a>
					</div>
					<div class="space-y-4 rounded-2xl bg-slate-950/80 p-4 font-mono text-sm text-slate-300">
						<p><span class="text-emerald-300">$</span> omnimon status --format json</p>
						<p class="text-sky-300">desktop: ready</p>
						<p class="text-slate-400">security: signed releases, native keyring only</p>
						<p class="text-slate-400">qa: frontend coverage gate + rust tests green</p>
						<p class="text-slate-400">alerts: reality-fix applied</p>
						<p class="text-orange-300">version: {releaseVersion}</p>
					</div>
					<div class="mt-5 grid gap-3 text-sm text-slate-300 sm:grid-cols-2">
						<div class="rounded-2xl border border-slate-800 bg-slate-950/60 p-4">
							<p class="text-white">QA reforzado</p>
							<p class="mt-1 text-slate-400">Cobertura, ramas criticas y regresiones bajo control.</p>
						</div>
						<div class="rounded-2xl border border-slate-800 bg-slate-950/60 p-4">
							<p class="text-white">CLI + GUI</p>
							<p class="mt-1 text-slate-400">Paridad funcional para diagnostico local y remoto.</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<section class="space-y-8">
			<div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
				<div>
					<p class="text-sm uppercase tracking-[0.24em] text-orange-200">Release {releaseVersion}</p>
					<h2 class="section-title mt-2 text-3xl font-bold text-white sm:text-4xl">Lo mas importante que cambia en esta version</h2>
				</div>
				<p class="max-w-2xl text-slate-400">Esta landing ya no arrastra contenido viejo: refleja el release actual, explica el estado real del producto y enlaza acciones verificables.</p>
			</div>

			<div class="grid gap-5 lg:grid-cols-2 xl:grid-cols-4">
				{releaseHighlights.map((item) => (
					<article class="glass-panel rounded-3xl p-6 transition hover:-translate-y-1 hover:border-slate-500/40">
						<h3 class="text-xl font-semibold text-white">{item.title}</h3>
						<p class="mt-3 text-sm leading-7 text-slate-300">{item.description}</p>
					</article>
				))}
			</div>
		</section>

		<section class="grid gap-6 lg:grid-cols-3">
			{productPillars.map((pillar) => (
				<article class="rounded-3xl border border-slate-800 bg-slate-900/40 p-7 transition hover:border-slate-600">
					<p class={`text-sm uppercase tracking-[0.24em] ${pillar.accent}`}>{pillar.title}</p>
					<p class="mt-4 text-lg leading-8 text-slate-300">{pillar.description}</p>
				</article>
			))}
		</section>

		<section class="glass-panel overflow-hidden rounded-[2rem]">
			<div class="grid gap-0 lg:grid-cols-[0.95fr_1.05fr]">
				<div class="border-b border-slate-800/80 px-6 py-8 lg:border-b-0 lg:border-r lg:px-8 lg:py-10">
					<p class="text-sm uppercase tracking-[0.24em] text-emerald-200">Flujo rapido</p>
					<h2 class="section-title mt-3 text-3xl font-bold text-white">Desde la terminal al panel visual sin cambiar de herramienta</h2>
					<div class="mt-8 space-y-6 text-sm leading-7 text-slate-300">
						<div>
							<h3 class="font-semibold text-white">omnimon monitor</h3>
							<p class="mt-1">Abre la vista interactiva para observar procesos, ranking y actividad del sistema en vivo.</p>
						</div>
						<div>
							<h3 class="font-semibold text-white">omnimon audit --security</h3>
							<p class="mt-1">Ejecuta validaciones locales y revisa superficie de riesgo con una salida pensada para operadores.</p>
						</div>
						<div>
							<h3 class="font-semibold text-white">omnimon optimize --ai anthropic --target browsers</h3>
							<p class="mt-1">Solicita analisis guiado por IA para detectar desperdicio de recursos y proponer acciones concretas.</p>
						</div>
					</div>
				</div>

				<div class="bg-slate-950/70 px-6 py-8 lg:px-8 lg:py-10">
					<div class="mb-4 flex gap-2">
						<div class="h-3 w-3 rounded-full bg-rose-400"></div>
						<div class="h-3 w-3 rounded-full bg-amber-300"></div>
						<div class="h-3 w-3 rounded-full bg-emerald-400"></div>
					</div>
					<pre class="overflow-x-auto rounded-2xl border border-slate-800 bg-black/60 p-5 text-sm leading-7 text-slate-300"><code>$ omnimon audit --security
[INFO] Starting security audit...
[OK] Release signature verification enabled
[OK] Native keyring storage enforced
[OK] AI rules rate limiting active
[OK] Alerts grouped by process
[DONE] OmniMon {releaseVersion} is ready</code></pre>
				</div>
			</div>
		</section>

		<section class="glass-panel rounded-[2rem] px-6 py-10 sm:px-8 lg:px-10">
			<div class="flex flex-col gap-4 text-center">
				<p class="text-sm uppercase tracking-[0.24em] text-emerald-200">Tutorial basico</p>
				<h2 class="section-title text-3xl font-bold text-white sm:text-4xl">Primeros pasos para usar OmniMon sin perderte</h2>
				<p class="mx-auto max-w-3xl text-slate-300">Si es tu primera vez, este recorrido corto te lleva desde el dashboard inicial hasta la validacion segura de una descarga.</p>
			</div>

			<div class="mt-8 grid gap-4 lg:grid-cols-4">
				{basicTutorial.map((item) => (
					<article class="rounded-3xl border border-slate-800 bg-slate-950/60 p-6 text-left">
						<p class="text-sm uppercase tracking-[0.24em] text-sky-200">Paso {item.step}</p>
						<h3 class="mt-3 text-xl font-semibold text-white">{item.title}</h3>
						<p class="mt-3 text-sm leading-7 text-slate-300">{item.description}</p>
					</article>
				))}
			</div>
		</section>

		<section id="download" class="glass-panel rounded-[2rem] px-6 py-10 sm:px-8 lg:px-10">
			<div class="flex flex-col gap-4 text-center">
				<p class="text-sm uppercase tracking-[0.24em] text-sky-200">Descarga e instalacion</p>
				<h2 class="section-title text-3xl font-bold text-white sm:text-4xl">Instala OmniMon {releaseVersion} en minutos</h2>
				<p class="mx-auto max-w-3xl text-slate-300">Usa el ultimo release, Homebrew o el instalador web segun tu plataforma. Antes de instalar, valida siempre el checksum publicado.</p>
			</div>

			<div class="mt-8 grid gap-4 lg:grid-cols-3">
				{downloadArtifacts.map((artifact) => (
					<a href={artifact.platform === 'Linux' ? installScriptUrl : releaseUrl} target="_blank" rel="noreferrer" class="rounded-3xl border border-slate-700 bg-slate-950/60 p-6 text-left transition hover:border-orange-400/50 hover:bg-slate-950">
						<p class={`text-sm uppercase tracking-[0.24em] ${artifact.accent}`}>{artifact.platform}</p>
						<h3 class="mt-3 text-xl font-semibold text-white">{artifact.name}</h3>
						<p class="mt-2 text-sm leading-7 text-slate-300">{artifact.description}</p>
						<p class="mt-4 text-xs uppercase tracking-[0.24em] text-slate-500">SHA-256</p>
						<p class="mt-2 text-sm leading-7 text-slate-300">{artifact.sha256}</p>
					</a>
				))}
			</div>

			<div class="mt-8 grid gap-4 lg:grid-cols-2">
				<div class="rounded-3xl border border-slate-800 bg-slate-950/70 p-6">
					<p class="text-sm uppercase tracking-[0.24em] text-slate-500">Homebrew</p>
					<pre class="mt-4 overflow-x-auto rounded-2xl bg-black/60 p-4 text-sm leading-7 text-slate-300"><code>brew tap chochy2001/omnimon
brew install --cask omnimon</code></pre>
				</div>
				<div class="rounded-3xl border border-slate-800 bg-slate-950/70 p-6">
					<p class="text-sm uppercase tracking-[0.24em] text-slate-500">Verificacion SHA-256</p>
					<pre class="mt-4 overflow-x-auto rounded-2xl bg-black/60 p-4 text-sm leading-7 text-slate-300"><code>shasum -a 256 OmniMon-{releaseVersion}-macOS-Universal.dmg
cat SHA256SUMS.txt</code></pre>
				</div>
			</div>

			<div class="mt-6 rounded-3xl border border-orange-400/20 bg-orange-500/10 p-6 text-sm leading-7 text-orange-50">
				<strong class="block text-base text-white">GitHub Sponsors</strong>
				<p class="mt-2">Si OmniMon te ahorra tiempo en soporte, monitoreo o seguridad, puedes sostener el proyecto desde GitHub Sponsors para acelerar fixes, releases y documentacion.</p>
				<a href={sponsorUrl} target="_blank" rel="noreferrer" class="mt-4 inline-flex items-center justify-center rounded-full bg-orange-500 px-5 py-2.5 font-semibold text-slate-950 transition hover:bg-orange-400">Apoyar en GitHub Sponsors</a>
			</div>
		</section>

		<section class="mx-auto w-full max-w-4xl space-y-6">
			<div class="text-center">
				<p class="text-sm uppercase tracking-[0.24em] text-orange-200">FAQ</p>
				<h2 class="section-title mt-2 text-3xl font-bold text-white">Preguntas frecuentes</h2>
			</div>
			<div class="space-y-4">
				{faqs.map((item) => (
					<details class="rounded-3xl border border-slate-800 bg-slate-900/45 p-5 transition open:border-slate-600">
						<summary class="cursor-pointer font-medium text-white transition hover:text-sky-200">{item.question}</summary>
						<p class="mt-4 text-sm leading-7 text-slate-300">{item.answer}</p>
					</details>
				))}
			</div>
		</section>
	</main>

	<footer class="mt-12 border-t border-slate-800/80 py-8 text-sm text-slate-400">
		<div class="mx-auto flex max-w-7xl flex-col gap-4 px-4 sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
			<p>&copy; {new Date().getFullYear()} OmniMon. Open source bajo MIT.</p>
			<div class="flex flex-wrap items-center gap-4">
				<a href="https://github.com/chochy2001/omnimon" target="_blank" rel="noreferrer" class="transition hover:text-white">GitHub</a>
				<a href={docsUrl} target="_blank" rel="noreferrer" class="transition hover:text-white">Documentacion</a>
				<a href="/blog/" class="transition hover:text-white">Blog</a>
				<a href={releaseUrl} target="_blank" rel="noreferrer" class="transition hover:text-white">Releases</a>
				<a href={sponsorUrl} target="_blank" rel="noreferrer" class="transition hover:text-orange-200">Patrocinar</a>
			</div>
		</div>
	</footer>
</Layout>
