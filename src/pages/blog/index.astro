---
import Layout from '../../layouts/Layout.astro';

const posts = [
	{
		slug: 'v6-5-0-release',
		title: 'OmniMon v6.5.0 — Smart Kill & Charts Fix',
		date: '12 Mar 2026',
		summary: 'Smart kill dialog with browser tab names, AI safety check button, fixed dynamic charts rendering, unified theme system, and browser tabs visible in basic mode.'
	},
	{
		slug: 'v6-4-1-release',
		title: 'OmniMon v6.4.1 — Reality Fix Release',
		date: '11 Mar 2026',
		summary: 'Solid colors across all themes, Lucide SVG icons, real AI streaming via SSE, full i18n with 531 keys, Pro Mode, 87% coverage and CVE quinn-proto resolved.'
	}
];
---

<Layout
	title="Blog | OmniMon"
	description="Release notes, tutorials and updates from the OmniMon project."
>
	<main class="mx-auto flex w-full max-w-4xl flex-col gap-12 px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
		<section class="space-y-6">
			<div class="flex items-center justify-between">
				<div>
					<p class="text-sm uppercase tracking-[0.24em] text-orange-200">Blog</p>
					<h1 class="section-title mt-2 text-4xl font-bold text-white sm:text-5xl">Release Notes &amp; Updates</h1>
				</div>
				<a href="/es/blog/" class="rounded-full border border-slate-700 px-4 py-2 text-sm text-slate-300 transition hover:border-sky-300/40 hover:text-white">ES</a>
			</div>
			<p class="max-w-2xl text-slate-400">What changed in each version of OmniMon, why it matters, and where to download it.</p>
		</section>

		<section class="space-y-6">
			{posts.map((post) => (
				<a href={`/blog/${post.slug}/`} class="block rounded-3xl border border-slate-800 bg-slate-900/40 p-6 transition hover:border-slate-600 hover:-translate-y-0.5">
					<div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
						<h2 class="text-xl font-semibold text-white">{post.title}</h2>
						<time class="text-sm text-slate-500">{post.date}</time>
					</div>
					<p class="mt-3 text-sm leading-7 text-slate-300">{post.summary}</p>
				</a>
			))}
		</section>

		<div class="flex items-center gap-4 text-sm text-slate-400">
			<a href="/" class="transition hover:text-white">&larr; Back to home</a>
		</div>
	</main>

	<footer class="mt-12 border-t border-slate-800/80 py-8 text-sm text-slate-400">
		<div class="mx-auto flex max-w-7xl flex-col gap-4 px-4 sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
			<p>&copy; {new Date().getFullYear()} OmniMon. Open source under MIT.</p>
			<div class="flex flex-wrap items-center gap-4">
				<a href="https://github.com/chochy2001/omnimon" target="_blank" rel="noreferrer" class="transition hover:text-white">GitHub</a>
				<a href="/" class="transition hover:text-white">Home</a>
				<a href="https://github.com/chochy2001/omnimon/releases/latest" target="_blank" rel="noreferrer" class="transition hover:text-white">Releases</a>
			</div>
		</div>
	</footer>
</Layout>
