---

<Layout
	title="Blog | OmniMon"
	description="Notas de release, tutoriales y novedades del proyecto OmniMon."
>
	<main class="mx-auto flex w-full max-w-4xl flex-col gap-12 px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
		<section class="space-y-6">
			<div class="flex items-center justify-between">
				<div>
					<p class="text-sm uppercase tracking-[0.24em] text-orange-200">Blog</p>
					<h1 class="section-title mt-2 text-4xl font-bold text-white sm:text-5xl">Notas de Release y Novedades</h1>
				</div>
				<a href="/blog/" class="rounded-full border border-slate-700 px-4 py-2 text-sm text-slate-300 transition hover:border-sky-300/40 hover:text-white">EN</a>
			</div>
			<p class="max-w-2xl text-slate-400">Que cambio en cada version de OmniMon, por que importa y donde descargarlo.</p>
		</section>

		<section class="space-y-6">
			{posts.map((post) => (
				<a href={`/es/blog/${post.slug}/`} class="block rounded-3xl border border-slate-800 bg-slate-900/40 p-6 transition hover:border-slate-600 hover:-translate-y-0.5">
					<div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
						<h2 class="text-xl font-semibold text-white">{post.title}</h2>
						<time class="text-sm text-slate-500">{post.date}</time>
					</div>
					<p class="mt-3 text-sm leading-7 text-slate-300">{post.summary}</p>
				</a>
			))}
		</section>

		<div class="flex items-center gap-4 text-sm text-slate-400">
			<a href="/" class="transition hover:text-white">&larr; Volver al inicio</a>
		</div>
	</main>

	<footer class="mt-12 border-t border-slate-800/80 py-8 text-sm text-slate-400">
		<div class="mx-auto flex max-w-7xl flex-col gap-4 px-4 sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
			<p>&copy; {new Date().getFullYear()} OmniMon. Open source bajo MIT.</p>
			<div class="flex flex-wrap items-center gap-4">
				<a href="https://github.com/chochy2001/omnimon" target="_blank" rel="noreferrer" class="transition hover:text-white">GitHub</a>
				<a href="/" class="transition hover:text-white">Inicio</a>
				<a href="https://github.com/chochy2001/omnimon/releases/latest" target="_blank" rel="noreferrer" class="transition hover:text-white">Releases</a>
			</div>
		</div>
	</footer>
</Layout>
