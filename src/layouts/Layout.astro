---
import '../styles/global.css';
import { OMNIMON_VERSION } from '../consts';

interface Props {
	title: string;
	description?: string;
}

const {
	title,
	description = `OmniMon ${OMNIMON_VERSION}: observabilidad, seguridad activa y asistentes de IA para macOS, Windows y Linux.`
} = Astro.props;
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : Astro.url.href;
---

<!doctype html>
<html lang="es" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="theme-color" content="#0b1220" />
		<link rel="canonical" href={canonicalUrl} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<meta name="generator" content={Astro.generator} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<title>{title}</title>
	</head>
	<body class="bg-slate-950 text-slate-200 font-sans antialiased min-h-screen selection:bg-indigo-500/30 pt-16">
		<nav class="fixed inset-x-0 top-0 z-50 h-16 border-b border-slate-800/80 bg-slate-950/95 backdrop-blur-sm">
			<div class="mx-auto flex h-full max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
				<a href="/" class="text-lg font-bold text-white tracking-tight">OmniMon</a>
				<div class="flex items-center gap-6 text-sm text-slate-300">
					<a href="/blog/" class="transition hover:text-white">Blog</a>
					<a href="https://github.com/chochy2001/omnimon#readme" target="_blank" rel="noreferrer" class="transition hover:text-white">Docs</a>
					<a href="https://github.com/chochy2001/omnimon" target="_blank" rel="noreferrer" class="transition hover:text-white">GitHub</a>
					<a href="https://github.com/chochy2001/omnimon/releases/latest" target="_blank" rel="noreferrer" class="inline-flex items-center rounded-full bg-orange-500 px-4 py-1.5 font-semibold text-slate-950 transition hover:bg-orange-400">Descargar</a>
				</div>
			</div>
		</nav>
		<slot />
	</body>
</html>
